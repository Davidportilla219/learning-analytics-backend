# Copy this to .env and fill in the values

# PostgreSQL (Railway managed DB or your own)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=changeme
DB_NAME=learning_analytics

# RabbitMQ (CloudAMQP free tier or Railway custom service)
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# JWT — generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-this-to-a-secure-random-string-minimum-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# CORS — comma-separated, no spaces
# Add your Vercel URL here
CORS_ORIGINS=https://your-app.vercel.app,http://localhost:3000

# Alert service specific
PORT=8005
