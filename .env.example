# Learning Analytics Platform - Environment Variables
# Copy this to .env and fill in the values

# =============================================================================
# RAILWAY DEPLOYMENT CONFIGURATION
# =============================================================================
# Railway automatically provides these variables for managed services:
# - POSTGRES_HOST, POSTGRES_PORT, POSTGRES_USER, POSTGRES_PASSWORD
# - RABBITMQ_HOST, RABBITMQ_PORT, RABBITMQ_USER, RABBITMQ_PASSWORD
# 
# For Railway deployment, you can use Railway service discovery with:
# DB_HOST = postgres
# RABBITMQ_HOST = rabbitmq

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# For Railway managed PostgreSQL:
DB_HOST=postgres
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=learning_analytics

# For self-hosted PostgreSQL (development):
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=your-secure-password-here
# DB_NAME=learning_analytics

# =============================================================================
# RABBITMQ MESSAGE BROKER CONFIGURATION
# =============================================================================
# Railway managed RabbitMQ (recommended for production):
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# For CloudAMQP (alternative):
# RABBITMQ_URL=amqp://your-cloudamqp-url
# RABBITMQ_HOST=your-cloudamqp-host
# RABBITMQ_PORT=5672
# RABBITMQ_USER=your-username
# RABBITMQ_PASSWORD=your-password

# =============================================================================
# JWT AUTHENTICATION CONFIGURATION
# =============================================================================
# Generate secure JWT secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# =============================================================================
# CORS CONFIGURATION
# =============================================================================
# Comma-separated list of allowed origins, NO SPACES
# Add your Vercel frontend URL here
CORS_ORIGINS=https://your-frontend.vercel.app,http://localhost:3000

# =============================================================================
# SERVICE CONFIGURATION
# =============================================================================
# Service ports (Railway will map these)
AUTH_PORT=8000
EVENT_PORT=8002
TELEMETRY_PORT=8003
RISK_PORT=8004
ALERT_PORT=8005
GATEWAY_PORT=8080

# Alert service specific
PORT=8005

# =============================================================================
# RAILWAY SERVICE DISCOVERY URLs
# =============================================================================
# Railway provides these URLs for each microservice when deployed
# These are automatically generated by Railway for each service
AUTH_SERVICE_URL=${RAILWAY_SERVICES_AUTH_SERVICE_URL:-http://localhost:8001}
EVENT_SERVICE_URL=${RAILWAY_SERVICES_EVENT_SERVICE_URL:-http://localhost:8002}
TELEMETRY_SERVICE_URL=${RAILWAY_SERVICES_TELEMETRY_SERVICE_URL:-http://localhost:8003}
RISK_SERVICE_URL=${RAILWAY_SERVICES_RISK_SERVICE_URL:-http://localhost:8004}
ALERT_SERVICE_URL=${RAILWAY_SERVICES_ALERT_SERVICE_URL:-http://localhost:8005}

# =============================================================================
# LOGGING AND DEBUGGING
# =============================================================================
DEBUG=false
LOG_LEVEL=INFO

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================
MAX_EVENT_SIZE=1048576
BATCH_SIZE=100
PROCESSING_TIMEOUT=30
ALERT_RETENTION_DAYS=30
